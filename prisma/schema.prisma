generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppState {
  id        String   @id @default(cuid())
  storeName String   @unique
  stateJson String // JSON serialized string of the Zustand state
  updatedAt DateTime @updatedAt
}

model PnrCache {
  id        String   @id @default(cuid())
  pnrNumber String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}
