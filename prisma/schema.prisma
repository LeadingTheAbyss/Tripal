generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppState {
  id        String   @id @default(cuid())
  storeName String   @unique
  stateJson String // JSON serialized string of the Zustand state
  updatedAt DateTime @updatedAt
}

model PnrCache {
  id        String   @id @default(cuid())
  pnrNumber String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}

model Flight {
  id        String   @id @default(cuid())
  flight_no String
  origin    String
  dest      String
  airline   String
  freq      String
  dep_time  String
  arr_time  String
  
  @@unique([flight_no, origin, dest, dep_time, arr_time])
}
