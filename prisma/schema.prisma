generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppState {
  id        String   @id @default(cuid())
  storeName String   @unique
  stateJson String // JSON serialized string of the Zustand state
  updatedAt DateTime @updatedAt
}

model PnrCache {
  id        String   @id @default(cuid())
  pnrNumber String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}

model Flight {
  id        String   @id @default(cuid())
  flight_no String
  origin    String
  dest      String
  airline   String
  freq      String
  dep_time  String
  arr_time  String
  
  @@unique([flight_no, origin, dest, dep_time, arr_time])
}

model Bus {
  id        String   @id @default(cuid())
  origin    String
  dest      String
  date      String
  bus_name  String
  timings   String
  price     Float
  
  @@unique([origin, dest, date, bus_name, timings])
}

model Train {
  id             String   @id @default(cuid())
  train_num      String
  train_name     String
  origin         String
  dest           String
  date           String
  dep_time       String
  arr_time       String
  duration_hours Float
  price          Float
  
  @@unique([train_num, origin, dest, date])
}

model Hotel {
  id              String   @id @default(cuid())
  hotel_id        String
  city            String
  check_in_date   String
  check_out_date  String
  name            String
  price           Float
  rating          Float
  lat             Float
  lon             Float
  
  @@unique([hotel_id, city, check_in_date, check_out_date])
}

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String
  picture         String?
  apiCalls        Int           @default(0)
  apiCallsFlights Int           @default(0)
  apiCallsTrains  Int           @default(0)
  apiCallsBusses  Int           @default(0)
  apiCallsHotels  Int           @default(0)
  apiCallsPlaces  Int           @default(0)
  lastApiCallDate DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  sessions        Session[]
  tripHistories   TripHistory[]
  savedPassengers SavedPassenger[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model TripHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination String
  snapshot    Json
  createdAt   DateTime @default(now())
}

model SavedPassenger {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  age       Int
  gender    String
  city      String?
  createdAt DateTime @default(now())
  
  @@unique([userId, name])
}
